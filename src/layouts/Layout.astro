---
import '../styles/global.css';
const { title = "Wildlife | Seven Continents" } = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{title}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@400;600&family=Inter:wght@300;400;500&display=swap" rel="stylesheet">
</head>
<body>
    <nav class="main-nav">
        <a href="/" class="logo">Wildlife</a>
        <div class="nav-links">
            <a href="/continents">Continents</a>
            <a href="/about">About</a>
        </div>
    </nav>
    
    <main>
        <slot />
    </main>
    
    <footer>
        <p>A conservation photography project by nx3creations</p>
    </footer>
</body>
</html>

<style>
    .main-nav {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 1.5rem 3rem;
        position: fixed;
        top: 0;
        left: 0;
        right: 0;
        z-index: 100;
        background: linear-gradient(to bottom, rgba(0,0,0,0.8), transparent);
    }
    
    .logo {
        font-family: 'Cormorant Garamond', serif;
        font-size: 1.5rem;
        font-weight: 600;
        color: white;
        text-decoration: none;
        letter-spacing: 0.1em;
    }
    
    .nav-links a {
        color: white;
        text-decoration: none;
        margin-left: 2rem;
        font-family: 'Inter', sans-serif;
        font-weight: 300;
        font-size: 0.9rem;
        letter-spacing: 0.05em;
        transition: opacity 0.3s;
    }
    
    .nav-links a:hover {
        opacity: 0.7;
    }
    
    footer {
        text-align: center;
        padding: 3rem;
        color: #666;
        font-family: 'Inter', sans-serif;
        font-size: 0.85rem;
    }
</style>