---
import '../styles/global.css';
const { title = "Wildlife | Seven Continents" } = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{title}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@400;600&family=Inter:wght@300;400;500&display=swap" rel="stylesheet">
</head>
<body>
    <nav class="main-nav">
        <a href="/" class="logo">Wildlife</a>
        <div class="nav-links">
            <a href="/continents">Continents</a>
            <a href="/about">About</a>
        </div>
    </nav>
    
    <main>
        <slot />
    </main>
    
    <footer>
        <p>A conservation photography project</p>
    </footer>
</body>
</html>

<style>
    .main-nav {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 1.5rem 2.5rem;
        position: fixed;
        top: 0;
        left: 0;
        right: 0;
        z-index: 100;
        background: linear-gradient(to bottom, rgba(5,5,5,0.9) 0%, transparent 100%);
        pointer-events: none;
    }

    .main-nav > * {
        pointer-events: auto;
    }
    
    .logo {
        font-family: 'Cormorant Garamond', serif;
        font-size: 1.25rem;
        font-weight: 400;
        color: white;
        text-decoration: none;
        letter-spacing: 0.15em;
        opacity: 0.9;
        transition: opacity 0.3s;
    }

    .logo:hover {
        opacity: 1;
    }
    
    .nav-links a {
        color: rgba(255, 255, 255, 0.7);
        text-decoration: none;
        margin-left: 1.5rem;
        font-family: 'Inter', sans-serif;
        font-weight: 300;
        font-size: 0.8rem;
        letter-spacing: 0.08em;
        text-transform: uppercase;
        transition: color 0.3s;
    }
    
    .nav-links a:hover {
        color: white;
    }
    
    footer {
        text-align: center;
        padding: 4rem 2rem;
        color: rgba(255, 255, 255, 0.3);
        font-family: 'Inter', sans-serif;
        font-size: 0.75rem;
        letter-spacing: 0.05em;
    }
</style>
