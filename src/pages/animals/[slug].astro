---
import Layout from '../../layouts/Layout.astro';
import animalsData from '../../data/animals.json';

export async function getStaticPaths() {
  const animals = animalsData.animals;
  return animals.map((animal, index) => {
    // Find previous and next animals (cycling through all animals)
    const prevIndex = index === 0 ? animals.length - 1 : index - 1;
    const nextIndex = index === animals.length - 1 ? 0 : index + 1;
    
    return {
      params: { slug: animal.slug },
      props: { 
        animal,
        prevAnimal: animals[prevIndex],
        nextAnimal: animals[nextIndex]
      },
    };
  });
}

const { animal, prevAnimal, nextAnimal } = Astro.props;
const continent = animalsData.continents.find(c => c.name === animal.continent);

// Media paths - check for multiple extensions
const heroImage = animal.media?.heroImage;
const image2 = animal.media?.image2;
const videoUrl = animal.media?.video;

// Use local video file if available, otherwise fallback to external URL
function getVideoUrl(slug: string, externalUrl: string): string {
  // Always use local video path - the file should exist on the server
  return `/videos/${slug}.mp4`;
}

const processedVideoUrl = getVideoUrl(animal.slug, videoUrl);

// Build image paths - try different extensions if not specified
const getImagePath = (basePath: string) => {
  if (basePath && basePath.startsWith('http')) return basePath;
  if (basePath) return basePath;
  // Return slug without extension - browser will try .jpg, .png, etc
  return `/images/${animal.slug}`;
};

const heroImagePath = getImagePath(heroImage);
const image2Path = image2 ? getImagePath(image2) : null;
---

<Layout title={`${animal.name} | Wildlife`}>
  <!-- Previous/Next Navigation Arrows -->
  <a href={`/animals/${prevAnimal.slug}`} class="nav-arrow nav-arrow-prev" title={`Previous: ${prevAnimal.name}`}>
    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
      <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 19.5L8.25 12l7.5-7.5" />
    </svg>
    <span class="nav-arrow-label">{prevAnimal.name}</span>
  </a>
  
  <a href={`/animals/${nextAnimal.slug}`} class="nav-arrow nav-arrow-next" title={`Next: ${nextAnimal.name}`}>
    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
      <path stroke-linecap="round" stroke-linejoin="round" d="M8.25 4.5l7.5 7.5-7.5 7.5" />
    </svg>
    <span class="nav-arrow-label">{nextAnimal.name}</span>
  </a>

  <div class={`animal-hero ${processedVideoUrl ? 'has-video' : ''}`}>
    <!-- Video background (if exists) -->
    {processedVideoUrl && (
      <video 
        class="hero-video" 
        autoplay 
        muted 
        loop 
        playsinline
        poster={heroImagePath}
      >
        <source src={processedVideoUrl} type="video/mp4" />
      </video>
    )}
    
    <!-- Hero Image (shown when no video) -->
    <div class="hero-image" style={`background-image: url('${heroImagePath}')`}></div>
    
    <!-- Emoji fallback (if no image) -->
    <div class="hero-emoji-fallback">
      <span>{animal.emoji}</span>
    </div>
    
    <!-- Dark overlay for text readability -->
    <div class="hero-overlay"></div>
    
    <div class="hero-content">
      <span class="continent-label">{animal.continent}</span>
      <h1>{animal.name}</h1>
      <span class="scientific-name">{animal.scientificName}</span>
    </div>
  </div>

  <div class="meta-bar">
    <div class="meta-item">
      <span class="meta-label">Status</span>
      <span class={`status-badge status-${animal.status.toLowerCase().replace(/\s+/g, '-')}`}>
        {animal.status}
      </span>
    </div>
    <div class="meta-item">
      <span class="meta-label">Habitat</span>
      <span class="meta-value">{animal.stats.habitat}</span>
    </div>
    <div class="meta-item">
      <span class="meta-label">Diet</span>
      <span class="meta-value">{animal.stats.diet}</span>
    </div>
    <div class="meta-item">
      <span class="meta-label">Lifespan</span>
      <span class="meta-value">{animal.stats.lifespan}</span>
    </div>
    <div class="meta-item">
      <span class="meta-label">Weight</span>
      <span class="meta-value">{animal.stats.weight}</span>
    </div>
  </div>

  <article class="animal-content">
    <div class="content-wrapper">
      <!-- Two Image Gallery with Lightbox -->
      <section class="image-gallery">
        <div class="gallery-grid">
          <div class="gallery-item main-image" data-lightbox="true">
            <img src={heroImagePath} alt={`${animal.name} - Hero`} />
          </div>
          {image2Path && (
            <div class="gallery-item secondary-image" data-lightbox="true">
              <img src={image2Path} alt={`${animal.name} - Secondary`} />
            </div>
          )}
        </div>
      </section>

      <!-- Lightbox Modal -->
      <div id="lightbox" class="lightbox">
        <span class="lightbox-close">&times;</span>
        <img class="lightbox-content" id="lightbox-img" />
        <div class="lightbox-caption" id="lightbox-caption"></div>
      </div>

      <section class="description">
        <p class="lead">{animal.description}</p>
      </section>

      <section class="highlights">
        <h2>Key Facts</h2>
        <ul>
          {animal.highlights.map(highlight => (
            <li>{highlight}</li>
          ))}
        </ul>
      </section>

      <section class="conservation">
        <h2>Conservation</h2>
        <p>{animal.conservation}</p>
      </section>
    </div>
  </article>

  <div class="animal-navigation">
    <a href={`/continents/${continent?.slug}`} class="nav-link">
      ← Back to {animal.continent}
    </a>
    <a href="/continents" class="nav-link">
      All Continents →
    </a>
  </div>
</Layout>

<style>
  /* Ensure nav stays visible on animal pages */
  :global(.main-nav) {
    z-index: 1000 !important;
  }

  /* Previous/Next Navigation Arrows */
  .nav-arrow {
    position: fixed;
    top: 50%;
    transform: translateY(-50%);
    z-index: 100;
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.75rem;
    color: rgba(255, 255, 255, 0.35);
    text-decoration: none;
    transition: all 0.3s ease;
    background: transparent;
    border-radius: 50%;
  }

  .nav-arrow:hover {
    color: rgba(255, 255, 255, 0.95);
    background: rgba(0, 0, 0, 0.4);
    backdrop-filter: blur(4px);
  }

  .nav-arrow-prev {
    left: 1rem;
  }

  .nav-arrow-next {
    right: 1rem;
    flex-direction: row-reverse;
  }

  .nav-arrow svg {
    width: 32px;
    height: 32px;
    flex-shrink: 0;
    filter: drop-shadow(0 2px 4px rgba(0,0,0,0.5));
  }

  .nav-arrow-label {
    font-size: 0.7rem;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    max-width: 120px;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
    opacity: 0;
    transition: opacity 0.3s ease;
  }

  .nav-arrow:hover .nav-arrow-label {
    opacity: 1;
  }

  @media (max-width: 768px) {
    .nav-arrow {
      padding: 0.75rem;
    }
    
    .nav-arrow-prev {
      left: 0.5rem;
    }
    
    .nav-arrow-next {
      right: 0.5rem;
    }
    
    .nav-arrow-label {
      display: none;
    }
  }

  .animal-hero {
    height: 100vh;
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    background: #050505;
    margin-top: 0;
  }

  /* Video background */
  .hero-video {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    z-index: 2;
    border: none;
  }

  /* Image background (fallback) */
  .hero-image {
    position: absolute;
    inset: 0;
    background-size: cover;
    background-position: center;
    z-index: 1;
  }

  /* Hide image when video is present */
  .animal-hero.has-video .hero-image {
    display: none;
  }

  /* Emoji fallback */
  .hero-emoji-fallback {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    background: radial-gradient(ellipse at center, #111 0%, #050505 60%);
    z-index: 3;
  }

  .hero-emoji-fallback span {
    font-size: 50vh;
    opacity: 0.06;
    filter: blur(1px);
  }

  /* Hide emoji if image exists */
  .hero-image:not([style*="undefined"]) ~ .hero-emoji-fallback {
    display: none;
  }

  /* Dark overlay for text readability */
  .hero-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to bottom,
      rgba(5, 5, 5, 0.3) 0%,
      rgba(5, 5, 5, 0.1) 40%,
      rgba(5, 5, 5, 0.5) 100%
    );
    z-index: 4;
  }

  .hero-content {
    position: relative;
    z-index: 5;
    text-align: center;
    padding: 2rem;
  }

  .continent-label {
    display: block;
    font-size: 0.75rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.5);
    margin-bottom: 1rem;
  }

  .hero-content h1 {
    font-family: 'Cormorant Garamond', serif;
    font-size: clamp(2.5rem, 6vw, 4rem);
    font-weight: 400;
    letter-spacing: 0.12em;
    margin-bottom: 0.75rem;
    color: white;
    text-transform: uppercase;
  }

  .scientific-name {
    font-size: 1rem;
    font-style: italic;
    color: rgba(255, 255, 255, 0.5);
    letter-spacing: 0.03em;
  }

  .meta-bar {
    display: flex;
    justify-content: center;
    gap: 4rem;
    padding: 2.5rem 2rem;
    background: #080808;
    border-top: 1px solid rgba(255, 255, 255, 0.03);
    border-bottom: 1px solid rgba(255, 255, 255, 0.03);
    flex-wrap: wrap;
  }

  .meta-item {
    text-align: center;
  }

  .meta-label {
    display: block;
    font-size: 0.65rem;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: rgba(255, 255, 255, 0.3);
    margin-bottom: 0.5rem;
  }

  .meta-value {
    display: block;
    font-size: 0.85rem;
    color: rgba(255, 255, 255, 0.6);
  }

  .status-badge {
    display: inline-block;
    padding: 0.3rem 0.6rem;
    font-size: 0.65rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    border-radius: 2px;
  }

  .status-least-concern {
    background: rgba(76, 175, 80, 0.15);
    color: #81c784;
  }

  .status-near-threatened {
    background: rgba(255, 193, 7, 0.15);
    color: #ffd54f;
  }

  .status-vulnerable {
    background: rgba(255, 152, 0, 0.15);
    color: #ffb74d;
  }

  .status-endangered {
    background: rgba(244, 67, 54, 0.15);
    color: #e57373;
  }

  .status-critically-endangered {
    background: rgba(183, 28, 28, 0.2);
    color: #ef5350;
  }

  .animal-content {
    max-width: 800px;
    margin: 0 auto;
    padding: 4rem 2rem;
  }

  .content-wrapper section {
    margin-bottom: 3.5rem;
  }

  /* Featured Image Section */
  .image-gallery {
    margin-bottom: 3rem;
  }

  .gallery-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
  }

  .gallery-item {
    overflow: hidden;
    border-radius: 4px;
    aspect-ratio: 16/9;
  }

  .gallery-item img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    cursor: zoom-in;
    transition: transform 0.3s ease;
  }

  .gallery-item:hover img {
    transform: scale(1.02);
  }

  /* Lightbox Styles */
  .lightbox {
    display: none;
    position: fixed;
    z-index: 9999;
    left: 0;
    top: 0;
    width: 100%;
    height: 100%;
    background-color: rgba(0, 0, 0, 0.95);
    animation: fadeIn 0.3s ease;
  }

  .lightbox.active {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
  }

  @keyframes fadeIn {
    from { opacity: 0; }
    to { opacity: 1; }
  }

  .lightbox-content {
    max-width: 90%;
    max-height: 85%;
    object-fit: contain;
    animation: zoomIn 0.3s ease;
    cursor: zoom-out;
  }

  @keyframes zoomIn {
    from { 
      opacity: 0;
      transform: scale(0.8);
    }
    to { 
      opacity: 1;
      transform: scale(1);
    }
  }

  .lightbox-close {
    position: absolute;
    top: 20px;
    right: 40px;
    color: rgba(255, 255, 255, 0.7);
    font-size: 40px;
    font-weight: 300;
    cursor: pointer;
    transition: color 0.3s;
    z-index: 10000;
  }

  .lightbox-close:hover {
    color: white;
  }

  .lightbox-caption {
    color: rgba(255, 255, 255, 0.6);
    font-size: 0.9rem;
    margin-top: 1rem;
    text-align: center;
    max-width: 90%;
  }

  @media (max-width: 768px) {
    .gallery-grid {
      grid-template-columns: 1fr;
    }
    
    .lightbox-close {
      top: 10px;
      right: 20px;
      font-size: 30px;
    }
  }

  .description .lead {
    font-size: 1.15rem;
    line-height: 1.8;
    color: rgba(255, 255, 255, 0.6);
    font-weight: 300;
  }

  .highlights h2,
  .conservation h2 {
    font-family: 'Cormorant Garamond', serif;
    font-size: 1.25rem;
    font-weight: 400;
    margin-bottom: 1.5rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.8);
  }

  .highlights ul {
    list-style: none;
    padding: 0;
  }

  .highlights li {
    padding: 0.75rem 0;
    padding-left: 1.25rem;
    position: relative;
    color: rgba(255, 255, 255, 0.45);
    line-height: 1.7;
    font-size: 0.95rem;
  }

  .highlights li::before {
    content: "—";
    position: absolute;
    left: 0;
    color: rgba(255, 255, 255, 0.2);
  }

  .conservation p {
    color: rgba(255, 255, 255, 0.45);
    line-height: 1.8;
    font-size: 0.95rem;
  }

  .animal-navigation {
    display: flex;
    justify-content: space-between;
    max-width: 800px;
    margin: 0 auto;
    padding: 2.5rem 2rem;
    border-top: 1px solid rgba(255, 255, 255, 0.05);
  }

  .nav-link {
    color: rgba(255, 255, 255, 0.35);
    text-decoration: none;
    font-size: 0.7rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    transition: color 0.3s;
  }

  .nav-link:hover {
    color: rgba(255, 255, 255, 0.7);
  }

  @media (max-width: 768px) {
    .meta-bar {
      gap: 2rem;
    }

    .meta-item {
      flex: 1 1 40%;
    }

    .hero-emoji-fallback span {
      font-size: 35vh;
    }
  }
</style>

<script>
  // Lightbox functionality
  document.addEventListener('DOMContentLoaded', function() {
    const lightbox = document.getElementById('lightbox');
    const lightboxImg = document.getElementById('lightbox-img');
    const lightboxCaption = document.getElementById('lightbox-caption');
    const lightboxClose = document.querySelector('.lightbox-close');
    const galleryItems = document.querySelectorAll('.gallery-item[data-lightbox="true"]');

    // Open lightbox when clicking an image
    galleryItems.forEach(item => {
      item.addEventListener('click', function() {
        const img = this.querySelector('img');
        lightboxImg.src = img.src;
        lightboxCaption.textContent = img.alt;
        lightbox.classList.add('active');
        document.body.style.overflow = 'hidden'; // Prevent scrolling
      });
    });

    // Close lightbox when clicking the X
    lightboxClose.addEventListener('click', closeLightbox);

    // Close lightbox when clicking outside the image
    lightbox.addEventListener('click', function(e) {
      if (e.target === lightbox || e.target === lightboxImg) {
        closeLightbox();
      }
    });

    // Close lightbox with Escape key
    document.addEventListener('keydown', function(e) {
      if (e.key === 'Escape' && lightbox.classList.contains('active')) {
        closeLightbox();
      }
    });

    function closeLightbox() {
      lightbox.classList.remove('active');
      document.body.style.overflow = ''; // Restore scrolling
      lightboxImg.src = '';
    }
  });
</script>
