---
import Layout from '../../layouts/Layout.astro';
import animalsData from '../../data/animals.json';

export async function getStaticPaths() {
  return animalsData.animals.map(animal => ({
    params: { slug: animal.slug },
    props: { animal },
  }));
}

const { animal } = Astro.props;
const continent = animalsData.continents.find(c => c.name === animal.continent);
---

<Layout title={`${animal.name} | Wildlife`}>
  <div class="animal-hero">
    <div class="hero-visual">
      <span class="hero-emoji">{animal.emoji}</span>
    </div>
    <div class="hero-content">
      <span class="continent-label">{animal.continent}</span>
      <h1>{animal.name}</h1>
      <span class="scientific-name">{animal.scientificName}</span>
    </div>
  </div>

  <div class="meta-bar">
    <div class="meta-item">
      <span class="meta-label">Status</span>
      <span class={`status-badge status-${animal.status.toLowerCase().replace(/\s+/g, '-')}`}>
        {animal.status}
      </span>
    </div>
    <div class="meta-item">
      <span class="meta-label">Habitat</span>
      <span class="meta-value">{animal.stats.habitat}</span>
    </div>
    <div class="meta-item">
      <span class="meta-label">Diet</span>
      <span class="meta-value">{animal.stats.diet}</span>
    </div>
    <div class="meta-item">
      <span class="meta-label">Lifespan</span>
      <span class="meta-value">{animal.stats.lifespan}</span>
    </div>
    <div class="meta-item">
      <span class="meta-label">Weight</span>
      <span class="meta-value">{animal.stats.weight}</span>
    </div>
  </div>

  <article class="animal-content">
    <div class="content-wrapper">
      <section class="description">
        <p class="lead">{animal.description}</p>
      </section>

      <section class="highlights">
        <h2>Key Facts</h2>
        <ul>
          {animal.highlights.map(highlight => (
            <li>{highlight}</li>
          ))}
        </ul>
      </section>

      <section class="conservation">
        <h2>Conservation</h2>
        <p>{animal.conservation}</p>
      </section>
    </div>
  </article>

  <div class="animal-navigation">
    <a href={`/continents/${continent?.slug}`} class="nav-link">
      ← Back to {animal.continent}
    </a>
    <a href="/continents" class="nav-link">
      All Continents →
    </a>
  </div>
</Layout>

<style>
  .animal-hero {
    height: 85vh;
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    background: #050505;
  }

  .hero-visual {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    background: radial-gradient(ellipse at center, #111 0%, #050505 60%);
  }

  .hero-emoji {
    font-size: 50vh;
    opacity: 0.06;
    filter: blur(1px);
  }

  .hero-content {
    position: relative;
    z-index: 1;
    text-align: center;
    padding: 2rem;
  }

  .continent-label {
    display: block;
    font-size: 0.75rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.35);
    margin-bottom: 1rem;
  }

  .hero-content h1 {
    font-family: 'Cormorant Garamond', serif;
    font-size: clamp(2.5rem, 6vw, 4rem);
    font-weight: 400;
    letter-spacing: 0.12em;
    margin-bottom: 0.75rem;
    color: white;
    text-transform: uppercase;
  }

  .scientific-name {
    font-size: 1rem;
    font-style: italic;
    color: rgba(255, 255, 255, 0.4);
    letter-spacing: 0.03em;
  }

  .meta-bar {
    display: flex;
    justify-content: center;
    gap: 4rem;
    padding: 2.5rem 2rem;
    background: #080808;
    border-top: 1px solid rgba(255, 255, 255, 0.03);
    border-bottom: 1px solid rgba(255, 255, 255, 0.03);
    flex-wrap: wrap;
  }

  .meta-item {
    text-align: center;
  }

  .meta-label {
    display: block;
    font-size: 0.65rem;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: rgba(255, 255, 255, 0.3);
    margin-bottom: 0.5rem;
  }

  .meta-value {
    display: block;
    font-size: 0.85rem;
    color: rgba(255, 255, 255, 0.6);
  }

  .status-badge {
    display: inline-block;
    padding: 0.3rem 0.6rem;
    font-size: 0.65rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    border-radius: 2px;
  }

  .status-least-concern {
    background: rgba(76, 175, 80, 0.15);
    color: #81c784;
  }

  .status-near-threatened {
    background: rgba(255, 193, 7, 0.15);
    color: #ffd54f;
  }

  .status-vulnerable {
    background: rgba(255, 152, 0, 0.15);
    color: #ffb74d;
  }

  .status-endangered {
    background: rgba(244, 67, 54, 0.15);
    color: #e57373;
  }

  .status-critically-endangered {
    background: rgba(183, 28, 28, 0.2);
    color: #ef5350;
  }

  .animal-content {
    max-width: 700px;
    margin: 0 auto;
    padding: 4rem 2rem;
  }

  .content-wrapper section {
    margin-bottom: 3.5rem;
  }

  .description .lead {
    font-size: 1.15rem;
    line-height: 1.8;
    color: rgba(255, 255, 255, 0.6);
    font-weight: 300;
  }

  .highlights h2,
  .conservation h2 {
    font-family: 'Cormorant Garamond', serif;
    font-size: 1.25rem;
    font-weight: 400;
    margin-bottom: 1.5rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.8);
  }

  .highlights ul {
    list-style: none;
    padding: 0;
  }

  .highlights li {
    padding: 0.75rem 0;
    padding-left: 1.25rem;
    position: relative;
    color: rgba(255, 255, 255, 0.45);
    line-height: 1.7;
    font-size: 0.95rem;
  }

  .highlights li::before {
    content: "—";
    position: absolute;
    left: 0;
    color: rgba(255, 255, 255, 0.2);
  }

  .conservation p {
    color: rgba(255, 255, 255, 0.45);
    line-height: 1.8;
    font-size: 0.95rem;
  }

  .animal-navigation {
    display: flex;
    justify-content: space-between;
    max-width: 700px;
    margin: 0 auto;
    padding: 2.5rem 2rem;
    border-top: 1px solid rgba(255, 255, 255, 0.05);
  }

  .nav-link {
    color: rgba(255, 255, 255, 0.35);
    text-decoration: none;
    font-size: 0.7rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    transition: color 0.3s;
  }

  .nav-link:hover {
    color: rgba(255, 255, 255, 0.7);
  }

  @media (max-width: 768px) {
    .meta-bar {
      gap: 2rem;
    }

    .meta-item {
      flex: 1 1 40%;
    }

    .hero-emoji {
      font-size: 35vh;
    }
  }
</style>
