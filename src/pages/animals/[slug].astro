---
import Layout from '../../layouts/Layout.astro';
import animalsData from '../../data/animals.json';

export async function getStaticPaths() {
  return animalsData.animals.map(animal => ({
    params: { slug: animal.slug },
    props: { animal },
  }));
}

const { animal } = Astro.props;
const continent = animalsData.continents.find(c => c.name === animal.continent);

// Media paths - check for multiple extensions
const heroImage = animal.media?.heroImage;
const image2 = animal.media?.image2;
const videoUrl = animal.media?.video;

// Convert Google Drive URL to streaming video URL
function getGoogleDriveVideoUrl(url: string): string {
  if (!url) return '';
  if (!url.includes('drive.google.com')) return url;
  
  // Extract file ID from Google Drive URL
  const match = url.match(/\/d\/([a-zA-Z0-9_-]+)/);
  if (match && match[1]) {
    const fileId = match[1];
    // Use Google Drive's video streaming endpoint
    return `https://drive.google.com/file/d/${fileId}/preview`;
  }
  return url;
}

const processedVideoUrl = getGoogleDriveVideoUrl(videoUrl);

// Build image paths - try different extensions if not specified
const getImagePath = (basePath: string) => {
  if (basePath && basePath.startsWith('http')) return basePath;
  if (basePath) return basePath;
  // Return slug without extension - browser will try .jpg, .png, etc
  return `/images/${animal.slug}`;
};

const heroImagePath = getImagePath(heroImage);
const image2Path = image2 ? getImagePath(image2) : null;
---

<Layout title={`${animal.name} | Wildlife`}>
  <div class={`animal-hero ${processedVideoUrl ? 'has-video' : ''}`}>
    <!-- Video background (if exists) -->
    {processedVideoUrl && processedVideoUrl.includes('drive.google.com') ? (
      <iframe 
        class="hero-video"
        src={processedVideoUrl}
        allow="autoplay; encrypted-media"
        allowfullscreen
      ></iframe>
    ) : processedVideoUrl ? (
      <video 
        class="hero-video" 
        autoplay 
        muted 
        loop 
        playsinline
        poster={heroImagePath}
      >
        <source src={processedVideoUrl} type="video/mp4" />
      </video>
    ) : null}
    
    <!-- Hero Image (shown when no video) -->
    <div class="hero-image" style={`background-image: url('${heroImagePath}')`}></div>
    
    <!-- Emoji fallback (if no image) -->
    <div class="hero-emoji-fallback">
      <span>{animal.emoji}</span>
    </div>
    
    <!-- Dark overlay for text readability -->
    <div class="hero-overlay"></div>
    
    <div class="hero-content">
      <span class="continent-label">{animal.continent}</span>
      <h1>{animal.name}</h1>
      <span class="scientific-name">{animal.scientificName}</span>
    </div>
  </div>

  <div class="meta-bar">
    <div class="meta-item">
      <span class="meta-label">Status</span>
      <span class={`status-badge status-${animal.status.toLowerCase().replace(/\s+/g, '-')}`}>
        {animal.status}
      </span>
    </div>
    <div class="meta-item">
      <span class="meta-label">Habitat</span>
      <span class="meta-value">{animal.stats.habitat}</span>
    </div>
    <div class="meta-item">
      <span class="meta-label">Diet</span>
      <span class="meta-value">{animal.stats.diet}</span>
    </div>
    <div class="meta-item">
      <span class="meta-label">Lifespan</span>
      <span class="meta-value">{animal.stats.lifespan}</span>
    </div>
    <div class="meta-item">
      <span class="meta-label">Weight</span>
      <span class="meta-value">{animal.stats.weight}</span>
    </div>
  </div>

  <article class="animal-content">
    <div class="content-wrapper">
      <!-- Two Image Gallery -->
      <section class="image-gallery">
        <div class="gallery-grid">
          <div class="gallery-item main-image">
            <img src={heroImagePath} alt={`${animal.name} - Hero`} />
          </div>
          {image2Path && (
            <div class="gallery-item secondary-image">
              <img src={image2Path} alt={`${animal.name} - Secondary`} />
            </div>
          )}
        </div>
      </section>

      <section class="description">
        <p class="lead">{animal.description}</p>
      </section>

      <section class="highlights">
        <h2>Key Facts</h2>
        <ul>
          {animal.highlights.map(highlight => (
            <li>{highlight}</li>
          ))}
        </ul>
      </section>

      <section class="conservation">
        <h2>Conservation</h2>
        <p>{animal.conservation}</p>
      </section>
    </div>
  </article>

  <div class="animal-navigation">
    <a href={`/continents/${continent?.slug}`} class="nav-link">
      ← Back to {animal.continent}
    </a>
    <a href="/continents" class="nav-link">
      All Continents →
    </a>
  </div>
</Layout>

<style>
  /* Ensure nav stays visible on animal pages */
  :global(.main-nav) {
    z-index: 1000 !important;
  }

  .animal-hero {
    height: 100vh;
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    background: #050505;
    margin-top: 0;
  }

  /* Video background */
  .hero-video {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    z-index: 2;
    border: none;
  }

  /* Image background (fallback) */
  .hero-image {
    position: absolute;
    inset: 0;
    background-size: cover;
    background-position: center;
    z-index: 1;
  }

  /* Hide image when video is present */
  .animal-hero.has-video .hero-image {
    display: none;
  }

  /* Emoji fallback */
  .hero-emoji-fallback {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    background: radial-gradient(ellipse at center, #111 0%, #050505 60%);
    z-index: 3;
  }

  .hero-emoji-fallback span {
    font-size: 50vh;
    opacity: 0.06;
    filter: blur(1px);
  }

  /* Hide emoji if image exists */
  .hero-image:not([style*="undefined"]) ~ .hero-emoji-fallback {
    display: none;
  }

  /* Dark overlay for text readability */
  .hero-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to bottom,
      rgba(5, 5, 5, 0.3) 0%,
      rgba(5, 5, 5, 0.1) 40%,
      rgba(5, 5, 5, 0.5) 100%
    );
    z-index: 4;
  }

  .hero-content {
    position: relative;
    z-index: 5;
    text-align: center;
    padding: 2rem;
  }

  .continent-label {
    display: block;
    font-size: 0.75rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.5);
    margin-bottom: 1rem;
  }

  .hero-content h1 {
    font-family: 'Cormorant Garamond', serif;
    font-size: clamp(2.5rem, 6vw, 4rem);
    font-weight: 400;
    letter-spacing: 0.12em;
    margin-bottom: 0.75rem;
    color: white;
    text-transform: uppercase;
  }

  .scientific-name {
    font-size: 1rem;
    font-style: italic;
    color: rgba(255, 255, 255, 0.5);
    letter-spacing: 0.03em;
  }

  .meta-bar {
    display: flex;
    justify-content: center;
    gap: 4rem;
    padding: 2.5rem 2rem;
    background: #080808;
    border-top: 1px solid rgba(255, 255, 255, 0.03);
    border-bottom: 1px solid rgba(255, 255, 255, 0.03);
    flex-wrap: wrap;
  }

  .meta-item {
    text-align: center;
  }

  .meta-label {
    display: block;
    font-size: 0.65rem;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: rgba(255, 255, 255, 0.3);
    margin-bottom: 0.5rem;
  }

  .meta-value {
    display: block;
    font-size: 0.85rem;
    color: rgba(255, 255, 255, 0.6);
  }

  .status-badge {
    display: inline-block;
    padding: 0.3rem 0.6rem;
    font-size: 0.65rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    border-radius: 2px;
  }

  .status-least-concern {
    background: rgba(76, 175, 80, 0.15);
    color: #81c784;
  }

  .status-near-threatened {
    background: rgba(255, 193, 7, 0.15);
    color: #ffd54f;
  }

  .status-vulnerable {
    background: rgba(255, 152, 0, 0.15);
    color: #ffb74d;
  }

  .status-endangered {
    background: rgba(244, 67, 54, 0.15);
    color: #e57373;
  }

  .status-critically-endangered {
    background: rgba(183, 28, 28, 0.2);
    color: #ef5350;
  }

  .animal-content {
    max-width: 800px;
    margin: 0 auto;
    padding: 4rem 2rem;
  }

  .content-wrapper section {
    margin-bottom: 3.5rem;
  }

  /* Featured Image Section */
  .image-gallery {
    margin-bottom: 3rem;
  }

  .gallery-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
  }

  .gallery-item {
    overflow: hidden;
    border-radius: 4px;
    aspect-ratio: 16/9;
  }

  .gallery-item img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  @media (max-width: 768px) {
    .gallery-grid {
      grid-template-columns: 1fr;
    }
  }

  .description .lead {
    font-size: 1.15rem;
    line-height: 1.8;
    color: rgba(255, 255, 255, 0.6);
    font-weight: 300;
  }

  .highlights h2,
  .conservation h2 {
    font-family: 'Cormorant Garamond', serif;
    font-size: 1.25rem;
    font-weight: 400;
    margin-bottom: 1.5rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.8);
  }

  .highlights ul {
    list-style: none;
    padding: 0;
  }

  .highlights li {
    padding: 0.75rem 0;
    padding-left: 1.25rem;
    position: relative;
    color: rgba(255, 255, 255, 0.45);
    line-height: 1.7;
    font-size: 0.95rem;
  }

  .highlights li::before {
    content: "—";
    position: absolute;
    left: 0;
    color: rgba(255, 255, 255, 0.2);
  }

  .conservation p {
    color: rgba(255, 255, 255, 0.45);
    line-height: 1.8;
    font-size: 0.95rem;
  }

  .animal-navigation {
    display: flex;
    justify-content: space-between;
    max-width: 800px;
    margin: 0 auto;
    padding: 2.5rem 2rem;
    border-top: 1px solid rgba(255, 255, 255, 0.05);
  }

  .nav-link {
    color: rgba(255, 255, 255, 0.35);
    text-decoration: none;
    font-size: 0.7rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    transition: color 0.3s;
  }

  .nav-link:hover {
    color: rgba(255, 255, 255, 0.7);
  }

  @media (max-width: 768px) {
    .meta-bar {
      gap: 2rem;
    }

    .meta-item {
      flex: 1 1 40%;
    }

    .hero-emoji-fallback span {
      font-size: 35vh;
    }
  }
</style>
