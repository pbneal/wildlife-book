---
import Layout from '../../layouts/Layout.astro';

const animals = [
    {
        name: 'African Elephant',
        scientific: 'Loxodonta africana',
        status: 'Endangered',
        location: 'Amboseli National Park, Kenya',
        image: '/images/africa-elephant.png',
        excerpt: 'The largest land mammal on Earth, African elephants are ecosystem engineers that shape the landscapes they inhabit.'
    }
];
---

<Layout title="Africa | Wildlife">
    <div class="continent-hero">
        <div class="continent-hero-bg"></div>
        <h1>Africa</h1>
        <p>The cradle of wildlife, where the great megafauna still roam</p>
    </div>

    <section class="animals-section">
        <div class="animals-grid">
            {animals.map(animal => (
                <article class="animal-card">
                    <div class="animal-image">
                        <img src={animal.image} alt={animal.name} />
                    </div>
                    <div class="animal-content">
                        <span class="status-badge endangered">{animal.status}</span>
                        <h2>{animal.name}</h2>
                        <p class="scientific">{animal.scientific}</p>
                        <p class="excerpt">{animal.excerpt}</p>
                        <p class="location">📍 {animal.location}</p>
                        <a href={`/animals/${animal.name.toLowerCase().replace(' ', '-')}`} class="read-more">
                            Read the full story →
                        </a>
                    </div>
                </article>
            ))}
        </div>
        
        <div class="more-coming">
            <h3>More animals coming soon</h3>
            <p>Lion • Leopard • Rhino • Buffalo • Giraffe • Zebra • Cheetah</p>
        </div>
    </section>
</Layout>

<style>
    .continent-hero {
        height: 60vh;
        display: flex;
        flex-direction: column;
        justify-content: center;
        align-items: center;
        text-align: center;
        position: relative;
        background: linear-gradient(135deg, #2a1a1a 0%, #0a0a0a 100%);
    }
    
    .continent-hero h1 {
        font-family: 'Cormorant Garamond', serif;
        font-size: clamp(2.5rem, 6vw, 4rem);
        font-weight: 400;
        letter-spacing: 0.15em;
        margin-bottom: 1rem;
    }
    
    .continent-hero p {
        font-size: 1rem;
        opacity: 0.7;
        letter-spacing: 0.05em;
    }
    
    .animals-section {
        padding: 4rem 3rem;
        max-width: 1200px;
        margin: 0 auto;
    }
    
    .animals-grid {
        display: grid;
        gap: 3rem;
    }
    
    .animal-card {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 3rem;
        background: #111;
        border-radius: 4px;
        overflow: hidden;
    }
    
    .animal-image {
        aspect-ratio: 4/5;
        background: #1a1a1a;
    }
    
    .placeholder-image {
        width: 100%;
        height: 100%;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        color: #444;
    }
    
    .placeholder-image span {
        font-size: 4rem;
        margin-bottom: 1rem;
    }
    
    .animal-content {
        padding: 3rem;
        display: flex;
        flex-direction: column;
        justify-content: center;
    }
    
    .status-badge {
        display: inline-block;
        padding: 0.35rem 0.75rem;
        border-radius: 2px;
        font-size: 0.75rem;
        letter-spacing: 0.1em;
        text-transform: uppercase;
        width: fit-content;
        margin-bottom: 1.5rem;
    }
    
    .status-badge.endangered {
        background: #c92a2a;
        color: white;
    }
    
    .animal-content h2 {
        font-family: 'Cormorant Garamond', serif;
        font-size: 2.5rem;
        font-weight: 400;
        margin-bottom: 0.5rem;
    }
    
    .scientific {
        font-style: italic;
        opacity: 0.6;
        margin-bottom: 1.5rem;
    }
    
    .excerpt {
        font-size: 1.1rem;
        line-height: 1.8;
        margin-bottom: 1.5rem;
        opacity: 0.9;
    }
    
    .location {
        font-size: 0.9rem;
        opacity: 0.7;
        margin-bottom: 2rem;
    }
    
    .read-more {
        display: inline-block;
        color: #fff;
        text-decoration: none;
        letter-spacing: 0.1em;
        font-size: 0.9rem;
        font-weight: 500;
        padding: 0.75rem 1.5rem;
        border: 1px solid rgba(255,255,255,0.3);
        border-radius: 2px;
        transition: all 0.3s;
        margin-top: 1rem;
    }
    
    .read-more:hover {
        background: rgba(255,255,255,0.1);
        border-color: rgba(255,255,255,0.5);
    }
    
    .more-coming {
        text-align: center;
        margin-top: 6rem;
        padding: 3rem;
        border-top: 1px solid #222;
    }
    
    .more-coming h3 {
        font-family: 'Cormorant Garamond', serif;
        font-size: 1.5rem;
        font-weight: 400;
        margin-bottom: 1rem;
        opacity: 0.8;
    }
    
    .more-coming p {
        opacity: 0.5;
        letter-spacing: 0.05em;
    }
    
    @media (max-width: 768px) {
        .animal-card {
            grid-template-columns: 1fr;
        }
    }
</style>