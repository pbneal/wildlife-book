---
import Layout from '../../layouts/Layout.astro';
import StoryCard from '../../components/StoryCard.astro';
import animalsData from '../../data/animals.json';

export async function getStaticPaths() {
  return animalsData.continents.map(continent => ({
    params: { slug: continent.slug },
    props: { continent },
  }));
}

const { continent } = Astro.props;
const continentAnimals = animalsData.animals.filter(a => a.continent === continent.name);

// Helper to get animal image - uses media from animals.json
const getAnimalImage = (animal: any) => {
  // Use heroImage from media if available, otherwise fallback to slug-based path
  return animal.media?.heroImage || `/images/${animal.slug}.jpg`;
};

// Hero images for specific continents - use actual file paths
const heroImages: Record<string, string> = {
  'africa': '/images/lion.jpg',
};

const heroImage = heroImages[continent.slug];
---

<Layout title={`${continent.name} | Wildlife`}>
  <div class="continent-hero">
    {heroImage ? (
      <>
        <div class="hero-image" style={`background-image: url('${heroImage}')`}></div>
        <div class="hero-overlay"></div>
      </>
    ) : (
      <div class="hero-bg">
        <span class="hero-emoji">{continent.emoji}</span>
      </div>
    )}
    <div class="hero-content">
      <span class="continent-number">0{continent.order}</span>
      <h1>{continent.name}</h1>
      <p class="description">{continent.description}</p>
    </div>
  </div>

  <section class="section">
    <h2 class="section-title">Regions</h2>
    <div class="subregions-grid">
      {continent.subregions.map(sub => (
        <a href={`/regions/${sub.name.toLowerCase().replace(/\s+/g, '-')}`} class="subregion-item">
          <h3>{sub.name}</h3>
          <p class="countries">{sub.countries.join(', ')}</p>
          <p class="habitat">{sub.habitat}</p>
        </a>
      ))}
    </div>
  </section>

  {continentAnimals.length > 0 && (
    <section class="section" style="background: #080808;">
      <h2 class="section-title">Featured Animals</h2>
      <div class="story-grid story-grid--featured">
        {continentAnimals.map(animal => (
          <StoryCard
            href={`/animals/${animal.slug}`}
            image={getAnimalImage(animal)}
            emoji={animal.emoji}
            title={animal.name}
            subtitle={animal.scientificName}
            status={animal.status}
            size="small"
          />
        ))}
      </div>
    </section>
  )}

  <div class="continent-navigation">
    <a href="/continents" class="nav-link">← All Continents</a>
    <a href="/" class="nav-link">Home →</a>
  </div>
</Layout>

<style>
  .continent-hero {
    height: 85vh;
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    background: #0a0a0a;
  }

  .hero-image {
    position: absolute;
    inset: 0;
    background-size: cover;
    background-position: center;
    z-index: 1;
  }

  .hero-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to bottom,
      rgba(5, 5, 5, 0.4) 0%,
      rgba(5, 5, 5, 0.2) 40%,
      rgba(5, 5, 5, 0.6) 100%
    );
    z-index: 2;
  }

  .hero-bg {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    background: radial-gradient(ellipse at center, #1a1a1a 0%, #050505 70%);
  }

  .hero-emoji {
    font-size: 40vh;
    opacity: 0.08;
    filter: blur(2px);
  }

  .hero-content {
    position: relative;
    z-index: 3;
    text-align: center;
    padding: 2rem;
  }

  .continent-number {
    display: block;
    font-family: 'Cormorant Garamond', serif;
    font-size: 0.85rem;
    letter-spacing: 0.3em;
    color: rgba(255, 255, 255, 0.4);
    margin-bottom: 1rem;
    text-transform: uppercase;
  }

  .hero-content h1 {
    font-family: 'Cormorant Garamond', serif;
    font-size: clamp(2.5rem, 6vw, 4rem);
    font-weight: 400;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    margin-bottom: 1.5rem;
    color: white;
  }

  .description {
    font-size: 0.95rem;
    font-weight: 300;
    letter-spacing: 0.03em;
    color: rgba(255, 255, 255, 0.6);
    max-width: 500px;
    margin: 0 auto;
    line-height: 1.7;
  }

  .subregions-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: 1px;
    background: #0a0a0a;
  }

  .subregion-item {
    background: #050505;
    padding: 2rem;
    text-align: center;
    text-decoration: none;
    color: inherit;
    transition: background 0.3s;
  }

  .subregion-item:hover {
    background: #0a0a0a;
  }

  .subregion-item h3 {
    font-family: 'Cormorant Garamond', serif;
    font-size: 1.25rem;
    font-weight: 400;
    margin-bottom: 0.5rem;
    letter-spacing: 0.05em;
    color: rgba(255, 255, 255, 0.9);
  }

  .subregion-item .countries {
    font-size: 0.8rem;
    color: rgba(255, 255, 255, 0.4);
    margin-bottom: 0.5rem;
    letter-spacing: 0.02em;
  }

  .subregion-item .habitat {
    font-size: 0.75rem;
    color: rgba(255, 255, 255, 0.3);
    font-style: italic;
  }

  .continent-navigation {
    display: flex;
    justify-content: space-between;
    max-width: 1400px;
    margin: 0 auto;
    padding: 3rem 2rem;
    border-top: 1px solid rgba(255, 255, 255, 0.05);
  }

  .nav-link {
    color: rgba(255, 255, 255, 0.4);
    text-decoration: none;
    font-size: 0.75rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    transition: color 0.3s;
  }

  .nav-link:hover {
    color: rgba(255, 255, 255, 0.8);
  }

  @media (max-width: 768px) {
    .hero-emoji {
      font-size: 30vh;
    }
  }
</style>
