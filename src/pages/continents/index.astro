---
import Layout from '../../layouts/Layout.astro';
import animalsData from '../../data/animals.json';

const sortedContinents = animalsData.continents.sort((a, b) => a.order - b.order);
---

<Layout title="Continents | Wildlife">
  <div class="continents-list-hero">
    <h1>Seven Continents</h1>
    <p>A journey through the world's wildlife regions</p>
  </div>

  <div class="continents-list">
    {sortedContinents.map(continent => {
      const animalCount = animalsData.animals.filter(a => a.continent === continent.name).length;
      return (
        <a 
          href={`/continents/${continent.slug}`} 
          class="continent-list-item"
        >
          <span class="continent-number">0{continent.order}</span>
          <div class="continent-content">
            <h2>{continent.name}</h2>
            <p>{continent.description}</p>
            <div class="continent-meta">
              <span>{animalCount} animals</span>
              <span class="continent-emoji">{continent.emoji}</span>
            </div>
          </div>
          <span class="continent-arrow">→</span>
        </a>
      );
    })}
  </div>
</Layout>

<style>
  .continents-list-hero {
    padding: 8rem 2rem 4rem;
    text-align: center;
  }

  .continents-list-hero h1 {
    font-family: 'Cormorant Garamond', serif;
    font-size: clamp(2.5rem, 5vw, 4rem);
    font-weight: 400;
    letter-spacing: 0.1em;
    margin-bottom: 1rem;
  }

  .continents-list-hero p {
    font-size: 1.1rem;
    color: #888;
    letter-spacing: 0.05em;
  }

  .continents-list {
    max-width: 900px;
    margin: 0 auto;
    padding: 0 2rem 6rem;
  }

  .continent-list-item {
    display: flex;
    align-items: center;
    gap: 2rem;
    padding: 2.5rem 2rem;
    border-bottom: 1px solid #2a2a2a;
    text-decoration: none;
    color: inherit;
    transition: background 0.3s;
  }

  .continent-list-item:hover {
    background: #141414;
  }

  .continent-number {
    font-family: 'Cormorant Garamond', serif;
    font-size: 1.25rem;
    color: #444;
    min-width: 3rem;
  }

  .continent-content {
    flex: 1;
  }

  .continent-content h2 {
    font-family: 'Cormorant Garamond', serif;
    font-size: 1.75rem;
    font-weight: 400;
    margin-bottom: 0.5rem;
    letter-spacing: 0.05em;
  }

  .continent-content p {
    font-size: 0.95rem;
    color: #888;
    margin-bottom: 0.75rem;
  }

  .continent-meta {
    display: flex;
    gap: 1rem;
    align-items: center;
    font-size: 0.85rem;
  }

  .continent-emoji {
    font-size: 1.2rem;
  }

  .continent-arrow {
    font-size: 1.5rem;
    color: #444;
    transition: color 0.3s, transform 0.3s;
  }

  .continent-list-item:hover .continent-arrow {
    color: #fff;
    transform: translateX(4px);
  }

  @media (max-width: 640px) {
    .continent-list-item {
      flex-wrap: wrap;
      gap: 1rem;
    }

    .continent-arrow {
      display: none;
    }
  }
</style>
