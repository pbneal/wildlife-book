---
import Layout from '../layouts/Layout.astro';
import StoryCard from '../components/StoryCard.astro';
import animalsData from '../data/animals.json';
import fs from 'fs';
import path from 'path';

const sortedContinents = animalsData.continents.sort((a, b) => a.order - b.order);
const featuredAnimals = animalsData.animals.slice(0, 4);

// Helper to find actual image file with correct extension
function findImageFile(imagePath: string): string {
  if (imagePath?.startsWith('http')) return imagePath;
  if (imagePath?.match(/\.(jpg|jpeg|png|webp|gif)$/i)) return imagePath;
  
  const publicDir = path.join(process.cwd(), 'public');
  const baseName = imagePath;
  const extensions = ['.jpg', '.jpeg', '.png', '.webp'];
  
  for (const ext of extensions) {
    const fullPath = path.join(publicDir, baseName + ext);
    if (fs.existsSync(fullPath)) {
      return baseName + ext;
    }
  }
  
  return baseName + '.jpg';
}

// Helper to get animal image - uses media from animals.json
const getAnimalImage = (animal: any) => {
  const heroImage = animal.media?.heroImage;
  if (heroImage) {
    return findImageFile(heroImage);
  }
  return findImageFile(`/images/${animal.slug}`);
};

const getContinentImage = (slug: string) => {
  const continentImages: Record<string, string> = {
    'africa': '/images/lion',
  };
  const basePath = continentImages[slug];
  return basePath ? findImageFile(basePath) : null;
};
---

<Layout>
  <section class="hero">
    <div class="hero-bg" style="background-image: url('/images/african-elephant.jpg'); background-size: cover; background-position: center;"></div>
    <div class="hero-content">
      <h1>Wildlife</h1>
      <p>A journey through seven continents, captured through the lens of conservation photography</p>
      <a href="#continents" class="hero-cta">Explore</a>
    </div>
  </section>

  <section id="continents" class="section">
    <h2 class="section-title">Explore by Continent</h2>
    <div class="story-grid story-grid--continents">
      {sortedContinents.map(continent => {
        const animalCount = animalsData.animals.filter(a => a.continent === continent.name).length;
        const continentImage = getContinentImage(continent.slug);
        return (
          <StoryCard
            href={`/continents/${continent.slug}`}
            image={continentImage}
            emoji={!continentImage ? continent.emoji : undefined}
            title={continent.name}
            subtitle={`${animalCount} animals featured`}
            size="medium"
          />
        );
      })}
    </div>
  </section>

  {featuredAnimals.length > 0 && (
    <section class="section" style="background: #080808;">
      <h2 class="section-title">Featured Animals</h2>
      <div class="story-grid story-grid--featured">
        {featuredAnimals.map(animal => (
          <StoryCard
            href={`/animals/${animal.slug}`}
            image={getAnimalImage(animal)}
            emoji={animal.emoji}
            title={animal.name}
            subtitle={animal.continent}
            status={animal.status}
            size="small"
          />
        ))}
      </div>
    </section>
  )}

  <section class="about-section">
    <h2>About This Project</h2>
    <p>This book represents a journey across seven continents, exploring the world's most magnificent wildlife through AI-generated photography. Each animal is rendered with photorealistic detail, accompanied by research on their habitat, behavior, and conservation status.</p>
    <p>From the elephants of Africa to the penguins of Antarctica, these pages celebrate the diversity of life on Earth while highlighting the urgent need for conservation.</p>
    <a href="/about" class="about-link">Learn More</a>
  </section>
</Layout>
