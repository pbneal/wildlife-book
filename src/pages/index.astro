---
import Layout from '../layouts/Layout.astro';
import StoryCard from '../components/StoryCard.astro';
import animalsData from '../data/animals.json';

const sortedContinents = animalsData.continents.sort((a, b) => a.order - b.order);
const featuredAnimals = animalsData.animals.slice(0, 4);
---

<Layout>
  <section class="hero">
    <div class="hero-bg"></div>
    <div class="hero-content">
      <h1>Wildlife</h1>
      <p>A journey through seven continents, captured through the lens of conservation photography</p>
      <a href="#continents" class="hero-cta">Explore</a>
    </div>
  </section>

  <section id="continents" class="section">
    <h2 class="section-title">Explore by Continent</h2>
    <div class="story-grid story-grid--continents">
      {sortedContinents.map(continent => {
        const animalCount = animalsData.animals.filter(a => a.continent === continent.name).length;
        return (
          <StoryCard
            href={`/continents/${continent.slug}`}
            emoji={continent.emoji}
            title={continent.name}
            subtitle={`${animalCount} animals featured`}
            size="medium"
          />
        );
      })}
    </div>
  </section>

  {featuredAnimals.length > 0 && (
    <section class="section" style="background: #080808;">
      <h2 class="section-title">Featured Animals</h2>
      <div class="story-grid story-grid--featured">
        {featuredAnimals.map(animal => (
          <StoryCard
            href={`/animals/${animal.slug}`}
            title={animal.name}
            subtitle={animal.continent}
            status={animal.status}
            size="small"
          />
        ))}
      </div>
    </section>
  )}

  <section class="about-section">
    <h2>About This Project</h2>
    <p>This book represents a journey across seven continents, exploring the world's most magnificent wildlife through AI-generated photography. Each animal is rendered with photorealistic detail, accompanied by research on their habitat, behavior, and conservation status.</p>
    <p>From the elephants of Africa to the penguins of Antarctica, these pages celebrate the diversity of life on Earth while highlighting the urgent need for conservation.</p>
    <a href="/about" class="about-link">Learn More</a>
  </section>
</Layout>
